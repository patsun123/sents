{$DOMAIN} {
	encode zstd gzip

	# Tell well-behaved crawlers to stay out.
	handle /robots.txt {
		root * /srv
		file_server
	}

	# Tell everyone else (including scrapers that ignore robots.txt but honor
	# the X-Robots-Tag header — Google, Bing, DuckDuckGo do).
	header X-Robots-Tag "noindex, nofollow, noarchive, nosnippet"

	reverse_proxy api:8000
}
