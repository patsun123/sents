# ══════════════════════════════════════════════════════════════════════════════
# SSE — Environment Variable Reference
# Copy this file to .env and fill in real values before running.
# NEVER commit the real .env file (it is gitignored).
# ══════════════════════════════════════════════════════════════════════════════

# ── Domain (required for nginx TLS) ──────────────────────────────────────────
DOMAIN=sse.example.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sse
POSTGRES_USER=sse_admin
POSTGRES_PASSWORD=changeme_admin
# Generate a real secret with: openssl rand -hex 32

# Service-specific DB users (created by database/scripts/create_users.sql)
POSTGRES_URL_API=postgresql://sse_api:changeme_api@postgres:5432/sse
POSTGRES_URL_SCRAPER=postgresql://sse_scraper:changeme_scraper@postgres:5432/sse
POSTGRES_URL_PROCESSOR=postgresql://sse_processor:changeme_processor@postgres:5432/sse
POSTGRES_URL_PRICING=postgresql://sse_pricing:changeme_pricing@postgres:5432/sse

# ── Redis ─────────────────────────────────────────────────────────────────────
# Generate a real secret with: openssl rand -hex 16
REDIS_PASSWORD=sse_redis_dev_password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
# REDIS_MAX_CONNECTIONS: size the pool relative to your uvicorn worker count.
# A safe default is 10 x (number of uvicorn workers). At 5 workers, 50 is fine.
REDIS_MAX_CONNECTIONS=50

# ── Market data ───────────────────────────────────────────────────────────────
# MARKET_DATA_PROVIDER: "yfinance" (dev/free) or "finnhub" (prod)
MARKET_DATA_PROVIDER=yfinance
# Required only when MARKET_DATA_PROVIDER=finnhub
# Sign up at https://finnhub.io/ — free tier gives 60 calls/min
FINNHUB_API_KEY=your_finnhub_api_key_here

# ── Scraper ───────────────────────────────────────────────────────────────────
# Comma-separated list of proxy URLs. Leave empty to disable proxy rotation.
# Format: http://user:pass@host:port or socks5://host:port
PROXY_POOL_URLS=
# Reddit credentials (optional — improves rate limits on authenticated requests)
# Register an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SSE-Scraper/1.0
POSTS_PER_TICKER=25

# ── Sentinel config ───────────────────────────────────────────────────────────
# Path to the config YAML inside each service container (mounted as volume).
# The host file d:/github/sse_io/config.yaml is mounted at this path.
SSE_CONFIG_PATH=/app/config.yaml

# ── Backend API ───────────────────────────────────────────────────────────────
# CORS origins — comma-separated list of allowed origins.
# In dev, add http://localhost:5173 (Vite default port).
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://${DOMAIN}
DEBUG=false
LOG_LEVEL=INFO

# ── Frontend (Vite build-time env — must be prefixed VITE_) ──────────────────
# This is injected into the React bundle at build time; not a runtime secret.
VITE_API_BASE_URL=https://${DOMAIN}/api/v1

# ── Certbot / Let's Encrypt ───────────────────────────────────────────────────
# Email used for expiry notifications from Let's Encrypt
CERTBOT_EMAIL=admin@example.com

# ── Uptime Kuma ───────────────────────────────────────────────────────────────
# Access the dashboard at http://your-server:3001 after first boot.
# No config needed here — Kuma is configured via its web UI.

# ── HuggingFace (processor service) ──────────────────────────────────────────
# FinBERT model (~1.4 GB) is downloaded automatically on first processor startup.
# The huggingface_cache Docker volume persists it across restarts.
HF_HOME=/app/.cache/huggingface
# Set to 1 to suppress tqdm progress bars in container logs
TRANSFORMERS_NO_TQDM=1
