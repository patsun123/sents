# SentiX Environment Configuration
# Copy to .env and fill in values. Never commit .env to git.

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://sentix:sentix@postgres:5432/sentix

# Redis
REDIS_URL=redis://redis:6379/0

# Reddit OAuth (optional; only needed for the PRAW fallback lane)
# Register app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Sentiment classifier: "epic_rules" (default), "vader", or "finbert"
CLASSIFIER_BACKEND=epic_rules

# VADER neutral zone: compound scores in (-threshold, threshold) are discarded
VADER_NEUTRAL_THRESHOLD=0.05

# Pipeline settings
CYCLE_INTERVAL_MINUTES=15
ALERT_THRESHOLD=3

# Sentry error tracking (optional; alerting disabled if empty)
SENTRY_DSN=

# Logging
LOG_LEVEL=INFO
