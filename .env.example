# SSE Environment Configuration
# Copy to .env and fill in values. Never commit .env to git.

# Domain — set to your real domain for automatic HTTPS via Caddy
# Use "localhost" for local development (Caddy serves HTTP only)
DOMAIN=localhost

# PostgreSQL — change credentials for production!
POSTGRES_USER=sse
POSTGRES_PASSWORD=sse
POSTGRES_DB=sse

# Redis
REDIS_URL=redis://redis:6379/0

# Reddit OAuth (required for PRAW fallback lane)
# Register app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Sentiment classifier: "vader" (default) or "finbert"
CLASSIFIER_BACKEND=vader

# VADER neutral zone: compound scores in (-threshold, threshold) are discarded
VADER_NEUTRAL_THRESHOLD=0.05

# Pipeline settings
CYCLE_INTERVAL_MINUTES=15
ALERT_THRESHOLD=3

# Sentry error tracking (optional; alerting disabled if empty)
SENTRY_DSN=

# Logging
LOG_LEVEL=INFO
