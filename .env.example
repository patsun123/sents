# SentiX Environment Configuration
# Copy to .env and fill in values. Never commit .env to git.

# PostgreSQL
# The compose file derives DATABASE_URL from POSTGRES_PASSWORD for api + worker.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=sentix

# Redis
REDIS_URL=redis://redis:6379/0

# Reddit OAuth (optional; only needed for the PRAW fallback lane)
# Register app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Sentiment classifier: "epic_rules" (default), "vader", or "finbert"
CLASSIFIER_BACKEND=epic_rules

# VADER neutral zone: compound scores in (-threshold, threshold) are discarded
VADER_NEUTRAL_THRESHOLD=0.05

# Pipeline settings
CYCLE_INTERVAL_MINUTES=15
ALERT_THRESHOLD=3

# Sentry error tracking (optional; alerting disabled if empty)
SENTRY_DSN=

# Logging
LOG_LEVEL=INFO

# --- Production deploy only (docker-compose.prod.yml) ---
# Public hostname for Caddy to terminate TLS on. DNS A record must point here.
DOMAIN=sentix.example.com

# Tailscale IP of THIS droplet. Postgres binds only to this address so the
# home worker can reach it over the encrypted mesh, and the public internet
# cannot. On the droplet: `tailscale ip -4`
TAILSCALE_IP=

# --- Home worker only (docker-compose.home.yml) ---
# Tailscale IP of the DROPLET. The home worker uses this in its DATABASE_URL.
# Read it from the droplet with `tailscale ip -4`.
DROPLET_TAILSCALE_IP=
